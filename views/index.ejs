<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Poor Fish's Journey 🐟</title>
    <link rel="stylesheet" href="/css/styles.css">
    <!-- Leaflet.js CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" />
</head>
<body>

    <!-- 🔹 Navigation -->
    <%- include('partials/navbar') %>

    <!-- 🔹 Landing Page -->
    <section id="home">
        <h1>🐟 The Poor Fish Wants to See the World!</h1>
        <img src="/images/fish.png" alt="Poor Fish" class="fish-image">
    </section>
    <section id="countup">
        <h2>🐟 The Journey of the Fish</h2>
        <p>It all began on <strong>April 01, 2025</strong>... and it's still going!</p>
        
        <div class="countup-container">
            <div class="time-box">
                <span id="days">00</span>
                <p>Days</p>
            </div>
            <div class="time-box">
                <span id="hours">00</span>
                <p>Hours</p>
            </div>
            <div class="time-box">
                <span id="minutes">00</span>
                <p>Minutes</p>
            </div>
            <div class="time-box">
                <span id="seconds">00</span>
                <p>Seconds</p>
            </div>
        </div>
    
        <p class="mystery-text">"Every second counts in this journey... How far will it go?"</p>
    </section>

    <!-- 🔹 Live Map Section -->
    <section id="map-section">
        <h2>🌍 Where Has the Fish Traveled?</h2>
        <div id="map"></div>
    </section>
    <h2>Where Should the Fish Travel Next?</h2>
    <form id="manualTrackForm">
        <input type="text" id="city" placeholder="City (optional)" />
        <select id="country" required>
            <option value="" disabled selected>Select a Country</option>
            <% countryList.forEach(country => { %>
                <option value="<%= country.name %>"><%= country.name %></option>
            <% }); %>
        </select>
        <button type="submit">Send the Fish Here</button>
    </form>

    <!-- 🔹 User Comments Section -->
    <section id="comments">
        <h2>💬 Share Your Thoughts!</h2>
        <textarea id="userComment" placeholder="Type your message here..."></textarea>
        <center>
            <button onclick="postComment()">Submit</button>
        </center>
        <div id="commentList">
            <% comments.forEach(comment => { %>
                <p>
                    <% if (comment.flagUrl) { %>
                        <img src="<%= comment.flagUrl %>" alt="<%= comment.country %> flag" class="comment-flag">
                    <% } %>
                    <%= comment.text %> - <small><%= new Date(comment.timestamp).toLocaleString() %></small>
                </p>
            <% }); %>
        </div>
    </section>

    <!-- 🔹 Footer -->
    <%- include('partials/footer') %>

    <!-- 🔹 Leaflet.js Script -->
    <script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"></script>
    <script src="/js/script.js"></script>

</body>
</html>